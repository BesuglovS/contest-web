# ===========================================
# Contest-Web — Переменные окружения (шаблон)
# Скопируйте в .env и заполните значения
# ===========================================

# ─── Деплой (SSH) ───
# Адрес сервера (хост)
DEPLOY_SSH_HOST=
# Порт SSH (по умолчанию 22)
DEPLOY_SSH_PORT=22
# Пользователь SSH
DEPLOY_SSH_USER=root
# Путь к приватному ключу (опционально)
DEPLOY_SSH_KEY=
# Целевая директория на сервере (куда синхронизировать исходники)
DEPLOY_REMOTE_PATH=
# Пользователь веб-сервера (владелец data/ и sandbox/; по умолчанию www-data)
DEPLOY_WEB_USER=www-data